package papers.momot_mcp.benchmark_implementation

import at.ac.tuwien.big.momot.problem.unit.parameter.random.RandomListValue
import at.ac.tuwien.big.momot.^search.^fitness.dimension.TransformationLengthDimension
import at.ac.tuwien.big.momot.^search.solution.repair.TransformationPlaceholderRepairer
import org.moeaframework.core.operator.TournamentSelection
import org.moeaframework.core.operator.OnePointCrossover
import at.ac.tuwien.big.momot.^search.algorithm.operator.mutation.TransformationPlaceholderMutation
import at.ac.tuwien.big.momot.^search.algorithm.operator.mutation.TransformationParameterMutation
import at.ac.tuwien.big.moea.^experiment.executor.listener.SeedRuntimePrintListener

search = {
   model = {
      file = "model/cra_input.xmi"
   }
   solutionLength = 12

   transformations = {
      modules = [ "model/cra.henshin" ]
      parameterValues = {
         "CRA::assignFeature::featureName" : new RandomListValue(#["M1", "M2", "M3", "M4", "A1", "A2", "A3", "A4", "A5"])
      }
   }

   fitness = {
      objectives = {
         CRAIndex : maximize "classes->collect(c | let methods : Set(Method) = c.encapsulates->select(f | f.oclIsKindOf(Method))->collect(f | f.oclAsType(Method))->asSet() in let attributes : Set(Attribute) = c.encapsulates->select(f | f.oclIsKindOf(Attribute))->collect(f | f.oclAsType(Attribute))->asSet() in let features : Set(Feature) = c.encapsulates in let cohesion : Real = if features->size() <= 1 then 0.0 else (methods->collect(m | m.dataAccess->intersection(attributes)->size() + m.methodCall->intersection(methods->excluding(m))->size())->sum() * 1.0) / (features->size() * (features->size() - 1)) endif in let otherClasses : Set(Class) = classes->excluding(c) in let coupling : Real = if features->size() = 0 then 0.0 else otherClasses->collect(other | let otherMethods : Set(Method) = other.encapsulates->select(f | f.oclIsKindOf(Method))->collect(f | f.oclAsType(Method))->asSet() in let otherAttributes : Set(Attribute) = other.encapsulates->select(f | f.oclIsKindOf(Attribute))->collect(f | f.oclAsType(Attribute))->asSet() in let otherFeatures : Set(Feature) = other.encapsulates in if otherFeatures->size() = 0 then 0.0 else (methods->collect(m | m.dataAccess->intersection(otherAttributes)->size() + m.methodCall->intersection(otherMethods)->size())->sum() * 1.0) / (features->size() * otherFeatures->size()) endif)->sum() endif in cohesion - coupling)->sum() - (features->select(f | f.isEncapsulatedBy.oclIsUndefined())->size() * 10.0) - (classes->select(c | c.encapsulates->size() = 0)->size() * 10.0)"
         SolutionLength : minimize new TransformationLengthDimension
      }
      solutionRepairer = new TransformationPlaceholderRepairer
   }

   algorithms = {
      NSGA_II : moea.createNSGAII(
                  new TournamentSelection(2),
                  new OnePointCrossover(1.0),
                  new TransformationPlaceholderMutation(0.15),
                  new TransformationParameterMutation(0.1, orchestration.moduleManager))
   }
}

experiment = {
   populationSize = 200
   maxEvaluations = 50000
   nrRuns = 1
   progressListeners = [ new SeedRuntimePrintListener ]
}

results = {
   objectives = {
      outputFile = "out/objectives/overall_objectives.pf"
      printOutput
   }

   solutions = {
      outputFile = "out/solutions/overall_solutions.txt"
      outputDirectory = "out/solutions/all/"
   }

   models = {
      outputDirectory = "out/models/all/"
      printOutput
   }
}
