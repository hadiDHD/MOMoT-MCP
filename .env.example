# MOMoT Smart Agent Environment Variables
# Copy this file to .env and adjust as necessary for local development

# REST runner base URL
MOMOT_REST_BASE_URL=http://localhost:8080

# Path to henshin-agent bin dir (contains validate.mjs)
HENSHIN_AGENT_BIN=./henshin-agent/bin

# Path to Ecore validator
ECORE_VALIDATOR_BIN=./tools/ecore-validator

# Path to XMI validator
XMI_VALIDATOR_BIN=./tools/xmi-validator

# Path to MOMoT validator (existing)
MOMOT_VALIDATOR_BIN=./tools/momot-validator

# Generation retry limit for automatic repairs
AGENT_MAX_RETRIES=3

# Human-in-the-loop (HITL) protocol (set to false to disable and auto-approve in CI/CD)
HITL_ENABLED=true
