<?xml version="1.0" encoding="ASCII"?>
<cra:ClassModel xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:cra="http://momot.mcp/cra"
    xsi:schemaLocation="http://momot.mcp/cra cra.ecore"
    name="CRA_Model_A">
  <features xsi:type="cra:Attribute" xmi:id="A1" name="A1"/>
  <features xsi:type="cra:Attribute" xmi:id="A2" name="A2"/>
  <features xsi:type="cra:Attribute" xmi:id="A3" name="A3"/>
  <features xsi:type="cra:Attribute" xmi:id="A4" name="A4"/>
  <features xsi:type="cra:Attribute" xmi:id="A5" name="A5"/>
  <features xsi:type="cra:Method" xmi:id="M1" name="M1" dataAccess="#A1 #A2" methodCall="#M2"/>
  <features xsi:type="cra:Method" xmi:id="M2" name="M2" dataAccess="#A2 #A3" methodCall="#M3"/>
  <features xsi:type="cra:Method" xmi:id="M3" name="M3" dataAccess="#A3 #A4" methodCall="#M4"/>
  <features xsi:type="cra:Method" xmi:id="M4" name="M4" dataAccess="#A4 #A5"/>
</cra:ClassModel>
